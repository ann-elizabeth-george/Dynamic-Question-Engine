<file path="frontend/src/components/Loader.css">
.loader-overlay {
  position: fixed;
  inset: 0;
  background: rgba(12, 8, 29, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loader-spinner {
  position: relative;
  width: 100px;
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loader-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid transparent;
  animation: spinRing 1.4s linear infinite;
}

.loader-ring:nth-child(1) {
  border-top-color: #8a2be2;
  animation-delay: 0s;
}

.loader-ring:nth-child(2) {
  width: 75%;
  height: 75%;
  border-right-color: #00f2fe;
  animation-delay: 0.15s;
  animation-direction: reverse;
}

.loader-ring:nth-child(3) {
  width: 50%;
  height: 50%;
  border-bottom-color: #ff007f;
  animation-delay: 0.3s;
}

.loader-text {
  font-size: 0.7rem;
  color: #a9a9d6;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

@keyframes spinRing {
  to { transform: rotate(360deg); }
}
</file>

