:root {
  --font-heading: 'Outfit', sans-serif;
  --font-body: 'Plus Jakarta Sans', sans-serif;

  /* Color Palette - Dark Premium Theme */
  --bg-gradient: linear-gradient(135deg, #0f0c20 0%, #15102a 50%, #06020f 100%);
  --bg-color: #0c081d;
  --panel-bg: rgba(25, 18, 48, 0.45);
  --panel-border: rgba(255, 255, 255, 0.08);
  
  --primary: #8a2be2;
  --primary-hover: #9d4edd;
  --primary-glow: rgba(138, 43, 226, 0.4);
  
  --secondary: #00f2fe;
  --secondary-glow: rgba(0, 242, 254, 0.3);
  
  --accent: #ff007f;
  
  --text-primary: #f8f9fa;
  --text-secondary: #a9a9d6;
  --text-muted: #6b6b99;
  
  --success: #00e676;
  --error: #ff1744;
  --warning: #ffea00;
  
  --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* {
  margin: 0;
  padding: 0;
