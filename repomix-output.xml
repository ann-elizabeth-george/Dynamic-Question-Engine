<file path="frontend/src/components/Navbar.css">
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(15, 12, 32, 0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.navbar-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0.8rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.navbar-brand {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  font-family: 'Outfit', sans-serif;
  font-weight: 800;
  font-size: 1.3rem;
}

.brand-icon {
  color: #8a2be2;
  font-size: 1.5rem;
}

.brand-text {
  background: linear-gradient(90deg, #fff, #00f2fe);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.navbar-links {
  display: flex;
  gap: 1.5rem;
}

.nav-link {
  color: #a9a9d6;
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  transition: color 0.2s;
  position: relative;
}

.nav-link:hover {
  color: #fff;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, #8a2be2, #00f2fe);
  transition: width 0.3s;
}

.nav-link:hover::after {
  width: 100%;
}

.navbar-user {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.user-greeting {
  color: #a9a9d6;
  font-size: 0.85rem;
}

.btn-logout {
  background: rgba(255, 23, 68, 0.15);
  border: 1px solid rgba(255, 23, 68, 0.3);
  color: #ff1744;
  padding: 0.4rem 1rem;
  border-radius: 8px;
  cursor: pointer;
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 0.85rem;
  transition: all 0.2s;
}

.btn-logout:hover {
  background: rgba(255, 23, 68, 0.3);
}
